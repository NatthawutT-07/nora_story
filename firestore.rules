rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // SECURITY: ใช้ Custom Claims ตรวจสอบ Admin
    // ============================================
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
    
    // Fallback: ตรวจสอบ Admin จาก Email Whitelist (สำหรับ initial setup)
    function isAdminEmail() {
      return request.auth != null && 
        request.auth.token.email in ['admin@norastory.com', 'mymymy0526@gmail.com'];
    }
    
    // Combined admin check
    function hasAdminAccess() {
      return isAdmin() || isAdminEmail();
    }

    // ============================================
    // Stats Collection
    // ============================================
    match /stats/{documentId} {
      // Public read (for showing user count on homepage)
      allow read: if true;
      // Write only via Cloud Functions (admin SDK)
      allow write: if false;
    }
    
    // ============================================
    // Music Collection
    // ============================================
    match /music/{documentId} {
      // Public read (for demo music selection)
      allow read: if true;
      // Admin can add/edit/delete music
      allow write: if hasAdminAccess();
    }

    // ============================================
    // Orders Collection
    // ============================================
    match /orders/{orderId} {
      // Public: Read single order by ID (for story display)
      allow get: if true;
      
      // Create/Update/Delete only via Cloud Functions
      // This ensures all business logic runs server-side
      allow create, update, delete: if false;
      
      // Admin list access for real-time dashboard (optional)
      // Remove this if you want full Cloud Functions control
      allow list: if hasAdminAccess();
    }
    
    // ============================================
    // Payment Sessions (Omise)
    // ============================================
    match /payment_sessions/{sessionId} {
      // Public read (for frontend onSnapshot listener to check status)
      allow read: if true;
      // Write only via Cloud Functions (admin SDK)
      allow write: if false;
    }
    
    // ============================================
    // Default: Deny all other paths
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
