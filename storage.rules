rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ให้ Admin อ่าน/เขียนได้ทุกอย่าง
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // โฟลเดอร์สำหรับเก็บสลิปการโอนเงิน
    match /slips/{fileName} {
      // ให้ใครก็ได้อัปโหลดไฟล์ขนาดไม่เกิน 5MB และต้องเป็นรูปภาพ
      allow create: if request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      // ให้ใครก็ได้อ่านไฟล์ได้ (จำเป็นสำหรับ getDownloadURL ในฝั่ง frontend)
      allow read: if true;
    }

    // โฟลเดอร์สำหรับเก็บรูปภาพของ story
    match /uploads/{storyId}/{fileName} {
      // ให้ใครก็ได้อัปโหลดไฟล์ขนาดไม่เกิน 5MB และต้องเป็นรูปภาพ
      allow create: if request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      // ให้ใครก็ได้อ่านไฟล์ได้
      allow read: if true; 
    }
    
    // โฟลเดอร์สำหรับเก็บไฟล์รูปภาพ content ชั่วคราวก่อนสร้าง order สำเร็จ (ไฟล์จาก tier 2 ขึ้นไป)
    match /{fileName} {
      allow create: if fileName.matches('temp_.*') 
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow read: if fileName.matches('temp_.*');
    }

    // ============================================
    // SECURITY: ใช้ Custom Claims ตรวจสอบ Admin
    // ============================================
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
    
    function isAdminEmail() {
      return request.auth != null && 
        request.auth.token.email in ['admin@norastory.com', 'mymymy0526@gmail.com'];
    }
    
    function hasAdminAccess() {
      return isAdmin() || isAdminEmail();
    }
    
    // Helper: Validate image file
    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');
    }

    // ============================================
    // Slips (Payment slips - sensitive)
    // ============================================
    match /slips/{slipFile} {
      // Anyone can upload (for checkout)
      allow create: if isValidImage();
      // Public read is required for the client to get the download URL immediately after upload
      allow read: if true;
      // Only admin can modify/delete
      allow update, delete: if hasAdminAccess();
    }

    // ============================================
    // Content Uploads (Story images - public display)
    // ============================================
    match /uploads/{storyId}/{fileName} {
      // Anyone can upload (for checkout)
      allow create: if isValidImage();
      // Public read (for story display)
      allow read: if true;
      // Only admin can modify/delete
      allow update, delete: if hasAdminAccess();
    }
    
    match /uploads/{storyId} {
      allow list: if hasAdminAccess();
    }

    // ============================================
    // Extension Slips
    // ============================================
    match /extension_slips/{orderId}/{fileName} {
      allow create: if isValidImage();
      // Public read is required for getDownloadURL()
      allow read: if true;
      allow update, delete: if hasAdminAccess();
    }

    // ============================================
    // Edit Slips (Payment for additional edits)
    // ============================================
    match /edit_slips/{orderId}/{fileName} {
      allow create: if isValidImage();
      // Public read is required for getDownloadURL()
      allow read: if true;
      allow update, delete: if hasAdminAccess();
    }

    // ============================================
    // Edit Images (Replacement content images)
    // ============================================
    match /edit_images/{orderId}/{fileName} {
      allow create: if isValidImage();
      allow read: if true;
      allow update, delete: if hasAdminAccess();
    }

    // ============================================
    // Music Files (Admin upload only)
    // ============================================
    match /music/{fileName} {
      allow read: if true;
      allow create, update, delete: if hasAdminAccess();
    }

    // ============================================
    // Temporary files (Root level)
    // ============================================
    match /{fileName} {
      allow create: if fileName.matches('temp_.*') && isValidImage();
      allow read: if fileName.matches('temp_.*');
    }

    // ============================================
    // Default: Deny all other paths
    // ============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
